    author = {Sillitoe, Ian and Lewis, Tony E. and Cuff, Alison and Das, Sayoni and Ashford, Paul and Dawson, Natalie L. and Furnham, Nicholas and Laskowski, Roman A. and Lee, David and Lees, Jonathan G. and Lehtinen, Sonja and Studer, Romain A. and Thornton, Janet and Orengo, Christine A.},
